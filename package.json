{
  "name": "zustand-reset-manager",
  "version": "0.4.0",
  "description": "Central, type-safe reset for many Zustand stores at once (single store, group, or all) - re-runs your initializer so dynamic values are regenerated.",
  "keywords": [
    "zustand",
    "reset",
    "store",
    "state-management",
    "logout",
    "react",
    "vanilla"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrzej-stepien/zustand-reset-manager.git"
  },
  "homepage": "https://github.com/andrzej-stepien/zustand-reset-manager#readme",
  "bugs": "https://github.com/andrzej-stepien/zustand-reset-manager/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zustand": ">=4"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "happy-dom": "20.11.0",
    "immer": "11.1.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.5.1",
    "typescript": "5.7.2",
    "vitest": "4.1.10",
    "zustand": "5.0.2"
  },
  "overrides": {
    "tsup": {
      "esbuild": "0.28.1"
    }
  }
}
